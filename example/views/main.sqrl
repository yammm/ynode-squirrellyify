<!DOCTYPE html>
<html>
    <head>
        <title>{{ it.title }}</title>
    </head>
    <body>
        <main>
            {{@ block("content") }}
            {{@ try }}
            {{ it.body | safe }}
            {{# catch => err }}
            Uh-oh, error! Message was '{{ err.message }}'
            {{/ try }}
            {{/ block }}
        </main>
    </body>
</html>
